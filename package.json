{
  "name": "tauri-agent-tools",
  "version": "0.5.0",
  "description": "Agent-driven inspection toolkit for Tauri desktop apps",
  "type": "module",
  "bin": {
    "tauri-agent-tools": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cesarandreslopez/tauri-agent-tools"
  },
  "homepage": "https://cesarandreslopez.github.io/tauri-agent-tools/",
  "bugs": {
    "url": "https://github.com/cesarandreslopez/tauri-agent-tools/issues"
  },
  "keywords": [
    "tauri",
    "screenshot",
    "dom-inspection",
    "desktop-app",
    "cli",
    "agent-tools",
    "devtools",
    "cross-platform"
  ],
  "author": {
    "name": "Cesar Andres Lopez",
    "email": "cesarandreslopez@gmail.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "rust-bridge/",
    "examples/",
    ".agents/",
    "AGENTS.md"
  ],
  "agents": {
    "skills": ".agents/skills"
  },
  "license": "MIT"
}
